# Never bake env files into the image — Next auto-loads .env.production at build,
# which would leak secrets and override the NEXT_PUBLIC_* build args. Config comes
# from Kamal (build args + env.clear) instead.
.env
.env.*
Dockerfile*
docker-compose*.yml
README.md

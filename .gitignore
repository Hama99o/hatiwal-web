# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
# Turbopack-in-Docker artifact: when the dev server (running as root in the
# container) can't remove a .next it doesn't own, it renames the old one to
# .next-root-owned-orphan-<pid> instead of failing. Pure build cache, and
# often root-owned on disk — never commit it, whatever suffix it has.
/.next-root-owned-orphan-*

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
/test-results
/playwright-report
/blob-report
/.next-e2e
playwright/.cache
e2e/.auth
